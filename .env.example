TARGETS=https://your-website.vercel.app,https://vercel.com,https://docs.github.com
CHECK_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=15
ENABLE_BACKGROUND_MONITOR=false
CRON_SECRET=change-me
SERVICE_NAME=site-monitor
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-<region>.grafana.net/otlp
GRAFANA_CLOUD_OTLP_HEADERS=Authorization=Basic%20<base64-instance-id-and-token>
GRAFANA_CLOUD_INSTANCE_ID=<your-instance-id>
GRAFANA_CLOUD_API_TOKEN=<your-access-policy-token>
